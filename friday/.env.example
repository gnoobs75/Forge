# ─── LLM Provider ─────────────────────────────────────────────────

# Required — Grok (xAI) API key
XAI_API_KEY=xai-...

# ─── Model Overrides ─────────────────────────────────────────────
# Resolution priority: CLI flag > env var > default

# Override reasoning model (CLI: --model)
# FRIDAY_REASONING_MODEL=grok-4-1-fast-reasoning-latest

# Override fast model for utility tasks (CLI: --fast-model)
# FRIDAY_FAST_MODEL=grok-4-1-fast-non-reasoning

# ─── Identity (Genesis) ──────────────────────────────────────────

# Override identity prompt file location (default: ~/.friday/GENESIS.md)
# FRIDAY_GENESIS_PATH=/path/to/GENESIS.md

# ─── Gmail (OAuth 2.0) ───────────────────────────────────────────
# Both required for Gmail module to activate

# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret

# ─── Encryption ──────────────────────────────────────────────────

# Fallback master key for SecretStore when OS keychain is unavailable
# Must be at least 32 characters (AES-256-GCM)
# FRIDAY_SECRET_KEY=your-secret-key-at-least-32-chars

# ─── Notifications ───────────────────────────────────────────────

# Slack incoming webhook URL
# FRIDAY_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Generic webhook URL for notifications
# FRIDAY_WEBHOOK_URL=https://your-webhook-endpoint.example.com/notify

# Email webhook URL for notifications
# FRIDAY_EMAIL_WEBHOOK_URL=https://your-email-webhook.example.com/send

# ─── Remote Access ──────────────────────────────────────────────

# Set a secret token to enable access from outside localhost
# When set, remote clients must provide this token via ?token= or Authorization header
# FRIDAY_REMOTE_TOKEN=your-secret-here
