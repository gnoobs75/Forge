{
  "name": "the-forge",
  "version": "1.0.0",
  "description": "The Forge — AI-powered software development studio",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "electron .",
    "build": "vite build && electron-builder",
    "vite": "vite",
    "electron": "electron .",
    "init:hq-data": "node scripts/init-hq-data.cjs",
    "friday:setup": "bash friday-module/setup.sh",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "chokidar": "^3.6.0",
    "discord.js": "^14.25.1",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.13.0",
    "remark-gfm": "^4.0.1",
    "three": "^0.183.2",
    "ws": "^8.19.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "vite": "^6.0.0",
    "vitest": "^4.1.4",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.theforge.app",
    "productName": "The Forge",
    "directories": {
      "output": "dist-electron"
    }
  }
